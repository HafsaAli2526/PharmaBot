# ============================================================================
# PharmaAI .gitignore
# Configured for open-source deployment on HuggingFace and GitHub
# ============================================================================

# ── ENVIRONMENT & SECRETS ─────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# ── PYTHON BUILD & CACHE ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── VIRTUAL ENVIRONMENTS ──────────────────────────────────────────────────
venv/
ENV/
env/
.venv
.ENV

# ── POETRY & DEPENDENCIES ─────────────────────────────────────────────────
poetry.lock
poetry-cache/

# ── TESTING & QUALITY TOOLS ──────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.tox/
htmlcov/

# ── IDE & EDITOR FILES ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.swp
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/
.classpath
*.iml

# ── OS FILES ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
__MACOSX/
.Spotlight-V100
.Trashes
ehthumbs.db

# ── DATA & ARTIFACTS (Generated by scripts) ───────────────────────────────
# Local data directories - these should be downloaded/generated by users
data/logs/
data/raw/
data/processed/
data/*.faiss
data/index_*

# FAISS vectors and indices - too large for version control
*.faiss
index_*.json
*.idx

# ── MODEL FILES ───────────────────────────────────────────────────────────
# Downloaded pretrained models - users should run download_models.py
models/biobert/
models/chemberta/
models/clinicalberta/
models/slm/
models/slm_finetuned/
!models/.gitkeep

# HuggingFace model cache
.cache/
huggingface/

# ── DATABASE & LOGS ───────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.log
*.logs
logs/
*.pot
*.pid

# ── DOCKER & DEPLOYMENT ──────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml
.docker/

# ── LOCAL CONFIGURATION ───────────────────────────────────────────────────
*.local
*.private
local.settings.json

# ── CELERY & MESSAGE QUEUES ──────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── NOTEBOOKS & JUPYTER ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
!notebooks/*.ipynb

# ── TEMPORARY & MISC FILES ───────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.swp
.DS_Store
*.orig
*.rej

# ── NLP & SPACY MODELS ───────────────────────────────────────────────────
en_core_web_sm/
en_core_sci_sm/

# ── REDIS ─────────────────────────────────────────────────────────────────
dump.rdb
*.rdb

# ── POSTGRES ──────────────────────────────────────────────────────────────
pgadmin-data/
postgres-data/

# ── GRAFANA ───────────────────────────────────────────────────────────────
grafana-storage/

# ── BENCHMARKS & PROFILING ───────────────────────────────────────────────
benchmarks/*.json
profiling_*.txt

# ── BUILD ARTIFACTS ──────────────────────────────────────────────────────
*.so
*.o
*.a
*.la

# ── RASA BOT ARTIFACTS ───────────────────────────────────────────────────
rasa_bot/.rasa/
rasa_bot/models/
rasa_bot/logs/
rasa_bot/events.db

# ── PYCACHE FROM SCRIPTS ───────────────────────────────────────────────────
scripts/__pycache__/
scripts/**/__pycache__/
training/__pycache__/
training/**/__pycache__/

# ── VS CODE SPECIFIC ──────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# ── PRE-COMMIT ────────────────────────────────────────────────────────────
.pre-commit-framework

# ── KEEP THESE IMPORTANT FILES ────────────────────────────────────────────
# Ensure these are tracked:
!.gitkeep
!models/.gitkeep
!data/logs/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
